{
  "name": "@master4n/temporal-transformer-codemod",
  "version": "2.0.2",
  "description": "Codemod CLI for migrating @master4n/temporal-transformer callers from v1.x (1.3.0 was the last legacy moment-backed release) to v2.0.2 (Luxon-backed). Rewrites moment-style format-string tokens to Luxon syntax, converts [literal] escapes to 'literal', warns on untranslatable tokens, and can optionally bump the package.json dependency.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "temporal-transformer-codemod": "./bin/temporal-transformer-codemod.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "cross-env TZ=UTC jest"
  },
  "keywords": [
    "codemod",
    "temporal-transformer",
    "moment-to-luxon",
    "migration",
    "format-tokens",
    "jscodeshift",
    "v1-to-v2",
    "upgrade-tool"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Master4Novice/temporal-transformer-codemod.git"
  },
  "bugs": {
    "url": "https://github.com/Master4Novice/temporal-transformer-codemod/issues"
  },
  "homepage": "https://github.com/Master4Novice/temporal-transformer-codemod#readme",
  "author": "dwivna",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "jscodeshift": "^0.16.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/jscodeshift": "^0.12.0",
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.0",
    "typescript": "^5.8.3"
  }
}
